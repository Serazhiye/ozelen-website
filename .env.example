# --- Supabase (CMS content store) ---
# Project URL and the SERVICE ROLE key (Project Settings → API).
# The service-role key is a server-only secret — never expose it to the browser
# and never prefix it with NEXT_PUBLIC_. Access happens only in /api/content.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Storage bucket for uploaded images (optional; defaults to "site-images").
# SUPABASE_STORAGE_BUCKET=site-images

# --- Optional: gate admin writes ---
# When set, POST /api/content requires header x-admin-token with this value.
# The admin panel reads it from localStorage key "nb_admin_token".
# ADMIN_TOKEN=some-long-random-string
